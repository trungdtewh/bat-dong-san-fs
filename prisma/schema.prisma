generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUM: NGƯỜI DÙNG ────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  MANAGER
  ANALYST
  VIEWER
}

enum ProjectRole {
  OWNER
  EDITOR
  VIEWER
}

// ─── ENUM: DỰ ÁN ─────────────────────────────────────────────────────────────

enum ProjectType {
  CHUNG_CU
  DAT_NEN
  NHA_PHO
  SHOPHOUSE
  BIET_THU
  KHU_DO_THI
  KHU_CONG_NGHIEP
  MIXED_USE
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  SELLING
  HANDED_OVER
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum DocumentType {
  LEGAL
  DRAWING
  PLANNING
  PRICE_LIST
  OTHER
}

// ─── ENUM: KỊCH BẢN ──────────────────────────────────────────────────────────

enum ScenarioType {
  BASE
  OPTIMISTIC
  PESSIMISTIC
  CUSTOM
}

// ─── ENUM: TÀI CHÍNH ─────────────────────────────────────────────────────────

enum LandCostCategory {
  LAND_USE_FEE
  LAND_LEASE_FEE
  COMPENSATION
  RELOCATION
  SITE_PREPARATION
  LEGAL_FEES
  TAX_AND_FEES
  OTHER
}

enum CostCategory {
  LAND_CLEARANCE
  CONSTRUCTION
  INFRASTRUCTURE
  PROFESSIONAL_FEES
  MARKETING
  MANAGEMENT
  CONTINGENCY
  OTHER
}

enum ConstructionCostCategory {
  FOUNDATION
  STRUCTURE
  MEP
  FINISHING
  INFRASTRUCTURE
  PROFESSIONAL_FEES
  MANAGEMENT
  CONTINGENCY
  OTHER
}

enum DistributionType {
  UNIFORM
  S_CURVE
  FRONT_LOADED
  BACK_LOADED
  MANUAL
}

enum LoanType {
  BANK_LOAN
  BOND
  EQUITY_PARTNER
  MEZZANINE
  OTHER
}

enum LoanStatus {
  ACTIVE
  REPAID
  CANCELLED
}

enum RepaymentMethod {
  EQUAL_PRINCIPAL
  ANNUITY
  BULLET
  CUSTOM
}

enum EquitySourceType {
  OWNER_EQUITY
  JOINT_VENTURE
  PREFERRED_EQUITY
  STRATEGIC_INVESTOR
  OTHER
}

enum PriceUnit {
  PER_SQM
  PER_UNIT
}

enum RevenueProductType {
  APARTMENT
  LAND_PLOT
  TOWNHOUSE
  SHOPHOUSE
  VILLA
  OFFICE
  RETAIL
  OTHER
}

enum ScheduleType {
  LAND_PAYMENT
  CONSTRUCTION_PAYMENT
  LOAN_DISBURSEMENT
  LOAN_REPAYMENT
  REVENUE_COLLECTION
  EQUITY_CONTRIBUTION
}

// ─── MODEL: NGƯỜI DÙNG ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          UserRole  @default(VIEWER)
  isActive      Boolean   @default(true)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projectsCreated Project[]         @relation("ProjectCreatedBy")
  memberships     ProjectMember[]
  documents       ProjectDocument[]

  @@map("users")
}

// ─── MODEL: DỰ ÁN ────────────────────────────────────────────────────────────

model Project {
  id               String        @id @default(cuid())
  code             String        @unique
  name             String
  type             ProjectType
  status           ProjectStatus @default(PLANNING)
  currencyCode     String        @default("VND")
  province         String
  district         String?
  address          String?
  totalArea        Float
  buildableArea    Float?
  grossFloorArea   Float?
  commercialArea   Float?
  startDate        DateTime?
  endDate          DateTime?
  description      String?
  createdById      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  createdBy User?             @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  members   ProjectMember[]
  scenarios Scenario[]
  documents ProjectDocument[]

  @@map("projects")
}

model ProjectMember {
  id        String      @id @default(cuid())
  projectId String
  userId    String
  role      ProjectRole @default(VIEWER)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectDocument {
  id           String       @id @default(cuid())
  projectId    String
  type         DocumentType
  name         String
  description  String?
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  uploadedById String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id])

  @@index([projectId])
  @@index([uploadedById])
  @@map("project_documents")
}

// ─── MODEL: KỊCH BẢN ─────────────────────────────────────────────────────────

model Scenario {
  id                     String       @id @default(cuid())
  projectId              String
  name                   String
  type                   ScenarioType @default(BASE)
  description            String?
  isBase                 Boolean      @default(false)
  isActive               Boolean      @default(true)
  version                Int          @default(1)
  parentScenarioId       String?
  isSnapshot             Boolean      @default(false)
  durationMonths         Int?
  constructionStartMonth Int?
  salesStartMonth        Int?
  handoverStartMonth     Int?
  discountRate           Decimal?     @db.Decimal(10, 4)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  project        Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentScenario Scenario?  @relation("ScenarioVersions", fields: [parentScenarioId], references: [id], onDelete: SetNull)
  childScenarios Scenario[] @relation("ScenarioVersions")

  assumption          Assumption?
  landCosts           LandCost[]
  constructionPhases  ConstructionPhase[]
  contractPackages    ContractPackage[]
  constructionCosts   ConstructionCost[]
  productGroups       ProductGroup[]
  loans               Loan[]
  equityContributions EquityContribution[]
  cashFlowEntries     CashFlowEntry[]
  kpiSnapshot         KPISnapshot?

  @@index([projectId])
  @@index([parentScenarioId])
  @@map("scenarios")
}

// ─── MODEL: GIẢ ĐỊNH ─────────────────────────────────────────────────────────

model Assumption {
  id         String @id @default(cuid())
  scenarioId String @unique

  // Nhóm 1: Kinh tế vĩ mô
  inflationRate              Decimal  @db.Decimal(10, 4)
  priceEscalationRate        Decimal? @db.Decimal(10, 4)
  constructionEscalationRate Decimal? @db.Decimal(10, 4)
  landPriceEscalationRate    Decimal? @db.Decimal(10, 4)

  // Nhóm 2: Thuế & Phí
  corporateTaxRate    Decimal  @db.Decimal(10, 4)
  vatRate             Decimal  @db.Decimal(10, 4)
  landTransferTaxRate Decimal? @db.Decimal(10, 4)

  // Nhóm 3: Chi phí bán hàng
  salesCommissionRate Decimal  @db.Decimal(10, 4)
  marketingCostRate   Decimal? @db.Decimal(10, 4)

  // Nhóm 4: Dự phòng
  contingencyRate Decimal @db.Decimal(10, 4)

  // Nhóm 5: Cấu trúc vốn & Vay
  debtRatio         Decimal? @db.Decimal(10, 4)
  equityRatio       Decimal? @db.Decimal(10, 4)
  loanInterestRate  Decimal? @db.Decimal(10, 4)
  loanTenorMonths   Int?
  gracePeriodMonths Int?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@map("assumptions")
}

// ─── MODEL: CHI PHÍ ──────────────────────────────────────────────────────────

model LandCost {
  id           String           @id @default(cuid())
  scenarioId   String
  category     LandCostCategory @default(OTHER)
  name         String
  description  String?
  area         Float?
  unitPrice    Decimal?         @db.Decimal(20, 0)
  totalAmount  Decimal          @db.Decimal(20, 0)
  paymentMonth Int
  sequence     Int              @default(0)
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  scenario        Scenario         @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  paymentSchedule PaymentSchedule?

  @@index([scenarioId])
  @@map("land_costs")
}

model ConstructionPhase {
  id          String   @id @default(cuid())
  scenarioId  String
  name        String
  sequence    Int      @default(0)
  startMonth  Int
  endMonth    Int
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  scenario          Scenario          @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  packages          ContractPackage[]
  constructionCosts ConstructionCost[]

  @@index([scenarioId])
  @@map("construction_phases")
}

model ContractPackage {
  id                 String           @id @default(cuid())
  scenarioId         String
  phaseId            String
  name               String
  contractorName     String?
  contractValue      Decimal          @db.Decimal(20, 0)
  startMonth         Int
  endMonth           Int
  distributionType   DistributionType @default(UNIFORM)
  customDistribution Json?
  notes              String?
  sequence           Int              @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  scenario          Scenario          @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  phase             ConstructionPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  constructionCosts ConstructionCost[]

  @@index([scenarioId])
  @@index([phaseId])
  @@map("contract_packages")
}

model ConstructionCost {
  id          String                   @id @default(cuid())
  scenarioId  String
  phaseId     String?
  packageId   String?
  category    ConstructionCostCategory @default(OTHER)
  name        String
  description String?
  unit        String?
  quantity    Float?
  unitPrice   Decimal?                 @db.Decimal(20, 0)
  totalAmount Decimal                  @db.Decimal(20, 0)
  sequence    Int                      @default(0)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  scenario        Scenario           @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  phase           ConstructionPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  package         ContractPackage?   @relation(fields: [packageId], references: [id], onDelete: SetNull)
  paymentSchedule PaymentSchedule?

  @@index([scenarioId])
  @@index([phaseId])
  @@index([packageId])
  @@map("construction_costs")
}

// ─── MODEL: DOANH THU ────────────────────────────────────────────────────────

model ProductGroup {
  id          String             @id @default(cuid())
  scenarioId  String
  productCode String?
  name        String
  productType RevenueProductType @default(APARTMENT)
  totalUnits  Int
  area        Float?
  basePrice   Decimal            @db.Decimal(20, 0)
  priceUnit   PriceUnit          @default(PER_SQM)
  vatRate     Decimal            @db.Decimal(10, 4) @default(0.1000)
  notes       String?
  sequence    Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  scenario Scenario       @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  batches  ProductBatch[]

  @@index([scenarioId])
  @@map("product_groups")
}

model ProductBatch {
  id                  String       @id @default(cuid())
  scenarioId          String
  groupId             String
  name                String
  launchMonth         Int
  unitsOffered        Int
  priceAdjustmentRate Decimal      @db.Decimal(10, 4) @default(0.0000)
  salesVelocity       Decimal      @db.Decimal(10, 4)
  collectionSchedule  Json
  notes               String?
  sequence            Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  group ProductGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
  @@index([groupId])
  @@map("product_batches")
}

// ─── MODEL: VỐN VAY ──────────────────────────────────────────────────────────

model Loan {
  id                  String          @id @default(cuid())
  scenarioId          String
  name                String
  lenderName          String?
  type                LoanType
  status              LoanStatus      @default(ACTIVE)
  principalAmount     Decimal         @db.Decimal(20, 0)
  interestRate        Decimal         @db.Decimal(10, 4)
  tenorMonths         Int
  gracePeriodMonths   Int             @default(0)
  startMonth          Int
  capitalizedInterest Boolean         @default(false)
  repaymentMethod     RepaymentMethod @default(EQUAL_PRINCIPAL)
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  scenario             Scenario         @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  disbursementSchedule PaymentSchedule? @relation("LoanDisbursementSchedule")

  @@index([scenarioId])
  @@map("loans")
}

// ─── MODEL: GÓP VỐN ──────────────────────────────────────────────────────────

model EquityContribution {
  id              String          @id @default(cuid())
  scenarioId      String
  name            String
  contributorName String?
  sourceType      EquitySourceType @default(OWNER_EQUITY)
  totalAmount     Decimal          @db.Decimal(20, 0)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  scenario        Scenario         @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  paymentSchedule PaymentSchedule?

  @@index([scenarioId])
  @@map("equity_contributions")
}

// ─── MODEL: LỊCH THANH TOÁN ──────────────────────────────────────────────────

model PaymentSchedule {
  id                   String       @id @default(cuid())
  scheduleType         ScheduleType
  name                 String
  totalAmount          Decimal      @db.Decimal(20, 0)
  landCostId           String?      @unique
  constructionCostId   String?      @unique
  loanDisbursementId   String?      @unique
  equityContributionId String?      @unique
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  landCost           LandCost?           @relation(fields: [landCostId], references: [id], onDelete: Cascade)
  constructionCost   ConstructionCost?   @relation(fields: [constructionCostId], references: [id], onDelete: Cascade)
  loanDisbursement   Loan?               @relation("LoanDisbursementSchedule", fields: [loanDisbursementId], references: [id], onDelete: Cascade)
  equityContribution EquityContribution? @relation(fields: [equityContributionId], references: [id], onDelete: Cascade)

  milestones PaymentMilestone[]

  @@map("payment_schedules")
}

model PaymentMilestone {
  id           String   @id @default(cuid())
  scheduleId   String
  sequence     Int
  projectMonth Int
  amount       Decimal  @db.Decimal(20, 0)
  description  String?
  isPaid       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  schedule PaymentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, sequence])
  @@map("payment_milestones")
}

// ─── MODEL: DÒNG TIỀN & CHỈ TIÊU TÀI CHÍNH ──────────────────────────────────

model CashFlowEntry {
  id                  String   @id @default(cuid())
  scenarioId          String
  projectMonth        Int
  revenueCollection   Decimal  @default(0) @db.Decimal(20, 0)
  loanDisbursement    Decimal  @default(0) @db.Decimal(20, 0)
  equityInflow        Decimal  @default(0) @db.Decimal(20, 0)
  otherInflow         Decimal  @default(0) @db.Decimal(20, 0)
  landPayment         Decimal  @default(0) @db.Decimal(20, 0)
  constructionPayment Decimal  @default(0) @db.Decimal(20, 0)
  loanRepayment       Decimal  @default(0) @db.Decimal(20, 0)
  interestPayment     Decimal  @default(0) @db.Decimal(20, 0)
  taxPayment          Decimal  @default(0) @db.Decimal(20, 0)
  otherOutflow        Decimal  @default(0) @db.Decimal(20, 0)
  totalInflow         Decimal  @default(0) @db.Decimal(20, 0)
  totalOutflow        Decimal  @default(0) @db.Decimal(20, 0)
  netCashFlow         Decimal  @default(0) @db.Decimal(20, 0)
  cumulativeCashFlow  Decimal  @default(0) @db.Decimal(20, 0)
  computedAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, projectMonth])
  @@map("cash_flow_entries")
}

model KPISnapshot {
  id                     String   @id @default(cuid())
  scenarioId             String   @unique
  totalRevenue           Decimal? @db.Decimal(20, 0)
  totalCost              Decimal? @db.Decimal(20, 0)
  grossProfit            Decimal? @db.Decimal(20, 0)
  grossMargin            Decimal? @db.Decimal(10, 4)
  netProfit              Decimal? @db.Decimal(20, 0)
  netMargin              Decimal? @db.Decimal(10, 4)
  irr                    Decimal? @db.Decimal(10, 4)
  npv                    Decimal? @db.Decimal(20, 0)
  roi                    Decimal? @db.Decimal(10, 4)
  paybackPeriodMonths    Int?
  peakFundingRequirement Decimal? @db.Decimal(20, 0)
  peakFundingMonth       Int?
  computedAt             DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  scenario Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@map("kpi_snapshots")
}
