# ─────────────────────────────────────────────────────────────────────────────
# FS Dòng Tiền Bất Động Sản — Biến môi trường
# Sao chép file này thành .env và điền giá trị thực.
# File này được commit vào git. KHÔNG đặt giá trị thực vào đây.
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Chuỗi kết nối PostgreSQL.
#
# Vercel + Neon:
#   DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
#
# Railway:
#   DATABASE_URL="postgresql://postgres:pass@containers-us-west-xxx.railway.app:5432/railway"
#
# Local:
#   DATABASE_URL="postgresql://USER@localhost:5432/real_estate_cashflow"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/real_estate_cashflow"

# ── NEXTAUTH ──────────────────────────────────────────────────────────────────
# Bắt buộc trong production. Tạo giá trị ngẫu nhiên bằng lệnh:
#   openssl rand -base64 32
# Tối thiểu 32 ký tự. KHÔNG dùng giá trị mẫu này trong production.
NEXTAUTH_SECRET="REPLACE_WITH_OUTPUT_OF__openssl_rand_-base64_32"

# URL chính xác của ứng dụng, bao gồm scheme (https://).
# Development: http://localhost:3000
# Production Vercel: https://your-app.vercel.app
# Production custom domain: https://fs.yourcompany.com
NEXTAUTH_URL="https://your-domain.com"

# ── RUNTIME ───────────────────────────────────────────────────────────────────
# Vercel và Railway tự set NODE_ENV=production khi deploy.
# Chỉ cần set thủ công nếu dùng VPS hoặc Docker.
# NODE_ENV="production"
