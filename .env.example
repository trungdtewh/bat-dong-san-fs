# Kết nối database PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/real_estate_cashflow"

# NextAuth — bắt buộc trong production
# Tạo bằng: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-must-be-at-least-32-characters-long"
NEXTAUTH_URL="https://your-domain.com"

# Môi trường: development | test | production
NODE_ENV="development"
